#!/usr/bin/env bash
#
# Block direct pushes to master. Use a branch + pull request instead; CI runs the
# build and tests on the PR before it can merge. This is the private-repo stand-in
# for GitHub branch protection (which requires a public repo or GitHub Pro).
#
# Activate once per clone:  git config core.hooksPath .githooks
# Emergency bypass (admin):  git push --no-verify

protected_branch="master"

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/$protected_branch" ]; then
    echo "" >&2
    echo "✗ Direct pushes to '$protected_branch' are blocked." >&2
    echo "  Create a branch and open a PR (CI must pass to merge):" >&2
    echo "    git switch -c your-branch && git push -u origin your-branch && gh pr create" >&2
    echo "  Emergency bypass: git push --no-verify" >&2
    echo "" >&2
    exit 1
  fi
done

exit 0
