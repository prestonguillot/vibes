# Test Environment Variables
NODE_ENV=test
PORT=3001

# Spotify API (test credentials - use 127.0.0.1 not localhost)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/auth/spotify/callback

# YouTube API (test credentials - use 127.0.0.1 not localhost)
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://127.0.0.1:3001/auth/youtube/callback
YOUTUBE_API_KEY=your-youtube-api-key

# Security
CSRF_SECRET=test-csrf-secret-for-testing-only-not-production
