{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing: deliberately break the source and report which breakages NO test noticed. Coverage only proves a line ran; this proves a test would catch a regression in it. Scoped per phase from the CLI while working: npx stryker run --mutate src/sync/trackMatching.ts",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "reporters": ["html", "json", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "mutate": [
    "src/**/*.ts",
    "!src/types/**",
    "!src/server.ts",
    "public/js/**/*.js",
    "!public/vendor/**"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "jsonReporter": {
    "fileName": "reports/mutation/report.json"
  },
  "incremental": true,
  "incrementalFile": "reports/stryker-incremental.json"
}
