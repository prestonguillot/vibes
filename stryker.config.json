{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing: deliberately break the source and report which breakages NO test noticed. Coverage only proves a line ran; this proves a test would catch a regression in it.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "reporters": [
    "json",
    "clear-text",
    "progress"
  ],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/sync/**/*.ts",
    "src/youtube/**/*.ts",
    "src/auth/**/*.ts",
    "src/lib/**/*.ts",
    "src/spotify/**/*.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "jsonReporter": {
    "fileName": "reports/mutation/report.json"
  },
  "concurrency": 6
}
