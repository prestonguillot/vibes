<!DOCTYPE html>
<html>
<head>
  <title><%= service %> Connection Failed</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      text-align: center;
      padding: 50px;
      background: #dc3545;
      color: white;
    }
    .error {
      font-size: 24px;
      margin-bottom: 20px;
    }
  </style>
</head>
<body>
  <div class="error"><%= service %> Connection Failed</div>
  <p>Please try again. You can close this window.</p>
  <script>
    setTimeout(() => {
      window.close();
    }, 3000);
  </script>
</body>
</html>
