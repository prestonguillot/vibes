<!DOCTYPE html>
<html>
<head>
  <title><%= service %> Connection Failed</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="oauth-error-body">
  <div class="oauth-error-message"><%= service %> Connection Failed</div>
  <p>Please try again. You can close this window.</p>
  <script>
    setTimeout(() => {
      window.close();
    }, 3000);
  </script>
</body>
</html>
