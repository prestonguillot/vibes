<%
const serviceCapitalized = service.charAt(0).toUpperCase() + service.slice(1);
const buttonClass = service === 'spotify' ? 'btn-success' : 'btn-danger';
const alertClass = service === 'spotify' ? 'alert-warning' : 'alert-danger';
const loginUrl = `/auth/${service}/login`;
const hasError = error && error.trim().length > 0;
%>

<%
// Remove error from display - it will be shown in a modal instead
// This keeps the connection button area clean and prevents layout shifts
%>

<% if (typeof loading !== 'undefined' && loading) { %>
  <button class="btn <%= buttonClass %> connect-btn disabled" disabled data-service="<%= service %>" data-connected="loading">
    <span class="d-flex align-items-center justify-content-center">
      <div class="spinner-border spinner-border-sm spinner-xs me-2" role="status" aria-hidden="true"></div>
      Connecting...
    </span>
  </button>
<% } else if (connected) { %>
  <button class="btn <%= buttonClass %> connect-btn connected" disabled data-service="<%= service %>" data-connected="true">Connected</button>
<% } else { %>
  <% if (typeof isDebug !== 'undefined' && isDebug) { %>
    <button class="btn <%= buttonClass %> connect-btn" data-service="<%= service %>" data-connected="false" title="(Demo mode)" onclick="return false;">
      Connect <%= serviceCapitalized %>
    </button>
  <% } else { %>
    <a href="<%= loginUrl %>" class="btn <%= buttonClass %> connect-btn" data-service="<%= service %>" data-connected="false">
      Connect <%= serviceCapitalized %>
    </a>
  <% } %>
<% } %>
