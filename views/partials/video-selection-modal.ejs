<div class="modal-header">
  <h5 class="modal-title"><%= modalTitle %></h5>
  <button type="button" class="btn-close" data-dialog-close aria-label="Close"></button>
</div>

<div class="modal-body">
  <p class="text-muted mb-3"><%- instructionText %></p>

  <form class="video-search mb-3"
        hx-get="/api/playlistDetails/search/<%= trackId %>"
        hx-target="#video-results-list"
        hx-swap="innerHTML"
        hx-indicator="#video-results"
        hx-disabled-elt="find button">
    <input type="hidden" name="trackName" value="<%= trackName %>">
    <input type="hidden" name="artistName" value="<%= artistName %>">
    <input type="hidden" name="playlistId" value="<%= playlistId %>">
    <input type="hidden" name="currentVideoId" value="<%= currentVideoId || '' %>">
    <label for="video-search-input" class="form-label small text-muted mb-1">Search YouTube</label>
    <div class="d-flex gap-2 align-items-stretch">
      <input type="search" id="video-search-input" name="searchQuery"
             class="form-control" value="<%= searchQuery %>"
             placeholder="Search for a video…" autocomplete="off">
      <button type="submit" class="btn btn-primary punk-btn">Search</button>
    </div>
  </form>

  <div id="video-results" class="video-results">
    <div id="video-results-list">
      <%- include('./video-results.ejs', { videos: videos, searchQuery: searchQuery }) %>
    </div>
    <div class="video-results__loading" aria-hidden="true">
      <div class="spinner-border" role="status"><span class="visually-hidden">Searching…</span></div>
    </div>
  </div>
</div>

<div class="modal-footer">
  <form id="video-selection-form">
    <input type="hidden" name="newVideoId" id="hidden-new-video-id" value="">
    <input type="hidden" name="currentVideoId" value="<%= currentVideoId || '' %>">
    <input type="hidden" name="playlistId" value="<%= playlistId %>">

    <button type="button" class="btn btn-secondary punk-btn" data-dialog-close>
      Cancel
    </button>
    <button type="button" class="btn btn-primary punk-btn" id="confirm-selection-btn"
            hx-post="/api/playlistDetails/replace/<%= trackId %>"
            hx-include="#video-selection-form"
            hx-swap="none"
            hx-disabled-elt="#confirm-selection-btn, #videoSelectionModal [data-dialog-close]"
            data-playlist-id="<%= playlistId %>"
            disabled>
      Confirm Selection
    </button>
  </form>
</div>
