<div class="modal-header">
  <h5 class="modal-title"><%= modalTitle %></h5>
  <button type="button" class="btn-close" data-dialog-close aria-label="Close"></button>
</div>

<div class="modal-body">
  <p class="text-muted mb-3"><%- instructionText %></p>

  <div class="video-options">
    <% videos.forEach((video, index) => { %>
      <input type="radio" name="video-selection" id="video-<%= video.id %>" value="<%= video.id %>"
             class="video-option-radio hidden">
      <label for="video-<%= video.id %>" class="video-option p-3 border rounded mb-2" data-video-id="<%= video.id %>">
        <div class="d-flex align-items-start">
          <img src="<%= video.thumbnail %>" alt="Video thumbnail"
               class="video-option__thumbnail me-3">
          <div class="flex-grow-1">
            <div class="d-flex align-items-start justify-content-between gap-2">
              <div>
                <h6 class="mb-1"><%= video.title %></h6>
                <p class="text-muted small mb-1">by <%= video.channelTitle %></p>
                <p class="small mb-0 video-option__description--truncated">
                  <%= video.description.substring(0, 150) %><% if (video.description.length > 150) { %>...<% } %>
                </p>
              </div>
              <% if (video.matchScore) { %>
                <div class="match-score-badge match-score-badge--modal flex-shrink-0"
                     data-stars="<%= video.matchScore.stars %>"
                     data-score="<%= (video.matchScore.totalScore * 100).toFixed(0) %>"
                     data-color="<%= video.matchScore.color %>">
                  <div class="match-score-stars" style="color: <%= video.matchScore.color %>;">
                    <% for (let i = 0; i < 5; i++) { %>
                      <span class="star <%= i < Math.floor(video.matchScore.stars) ? 'star--filled' : i < video.matchScore.stars ? 'star--half' : '' %>">★</span>
                    <% } %>
                  </div>
                  <div class="match-score-tooltip">
                    <div class="tooltip-title">Match Score: <%= (video.matchScore.totalScore * 100).toFixed(0) %>%</div>
                    <div class="tooltip-components">
                      <% if (video.matchScore.components.coreMatch) { %>
                        <div>Title Match: +<%= (video.matchScore.components.coreMatch * 100).toFixed(0) %>%</div>
                      <% } %>
                      <% if (video.matchScore.components.fuzzySimilarity) { %>
                        <div>Fuzzy Match: +<%= (video.matchScore.components.fuzzySimilarity * 100).toFixed(0) %>%</div>
                      <% } %>
                      <% if (video.matchScore.components.wordMatching) { %>
                        <div>Word Match: +<%= (video.matchScore.components.wordMatching * 100).toFixed(0) %>%</div>
                      <% } %>
                      <% if (video.matchScore.components.artistBonus) { %>
                        <div>Artist Bonus: +<%= (video.matchScore.components.artistBonus * 100).toFixed(0) %>%</div>
                      <% } %>
                      <% if (video.matchScore.components.officialVideo) { %>
                        <div>Official Video: +<%= (video.matchScore.components.officialVideo * 100).toFixed(0) %>%</div>
                      <% } %>
                      <% if (video.matchScore.components.livePerformance) { %>
                        <div>Live Performance: +<%= (video.matchScore.components.livePerformance * 100).toFixed(0) %>%</div>
                      <% } %>
                      <% if (video.matchScore.components.viewCount) { %>
                        <div>High View Count: +<%= (video.matchScore.components.viewCount * 100).toFixed(0) %>%</div>
                      <% } %>
                    </div>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
          <div class="selection-indicator ms-2">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#28a745">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
            </svg>
          </div>
        </div>
      </label>
    <% }); %>
  </div>
</div>

<div class="modal-footer">
  <form id="video-selection-form">
    <input type="hidden" name="newVideoId" id="hidden-new-video-id" value="">
    <input type="hidden" name="currentVideoId" value="<%= currentVideoId || '' %>">
    <input type="hidden" name="playlistId" value="<%= playlistId %>">

    <button type="button" class="btn btn-secondary punk-btn" data-dialog-close>
      Cancel
    </button>
    <button type="button" class="btn btn-primary punk-btn" id="confirm-selection-btn"
            hx-post="/api/playlistDetails/replace/<%= trackId %>"
            hx-include="#video-selection-form"
            hx-swap="none"
            data-playlist-id="<%= playlistId %>"
            disabled>
      Confirm Selection
    </button>
  </form>
</div>
