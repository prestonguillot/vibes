<%
const loginUrl = service === 'Spotify' ? '/auth/spotify/login' : '/auth/youtube/login';
const btnClass = service === 'Spotify' ? 'btn-spotify-reconnect' : 'btn-youtube-reconnect';
%>

<div class="auth-expired-container">
  <h6><%= service %> session expired</h6>
  <p>Please reconnect to <%= service %> to continue.</p>
  <a href="<%= loginUrl %>" class="btn <%= btnClass %>">
    Reconnect to <%= service %>
  </a>
</div>
