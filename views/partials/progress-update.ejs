<%
const progressType = type || 'progress';
const progressBarClass = progressType === 'complete' ? 'bg-success' : 'bg-primary';
const showSpinner = progressType === 'progress' && percentage < 100;
%>

<% if (progressType === 'error') { %>
  <div class="sync-progress-container">
    <div class="d-flex align-items-center text-danger mb-2">
      <span class="progress-text"><%= message %></span>
    </div>
    <div class="progress mb-2 progress-height-6">
      <div class="progress-bar bg-danger progress-bar--full" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
    </div>
  </div>
<% } else { %>
  <div class="sync-progress-container">
    <div class="d-flex align-items-center mb-2">
      <% if (showSpinner) { %>
        <div class="spinner-border spinner-border-sm text-primary me-2" role="status">
          <span class="visually-hidden">Loading...</span>
        </div>
      <% } %>
      <span class="progress-text"><%= message %></span>
      <span class="progress-percentage ms-auto text-muted"><%= percentage %>%</span>
    </div>
    <% if (details) { %>
      <div class="progress-details text-muted small mb-1"><%= details %></div>
    <% } %>
    <div class="progress mb-2 progress-height-6">
      <div class="progress-bar progress-bar--dynamic <%= progressBarClass %>" role="progressbar" style="--progress-width: <%= percentage %>%" aria-valuenow="<%= percentage %>" aria-valuemin="0" aria-valuemax="100"></div>
    </div>
  </div>
<% } %>
