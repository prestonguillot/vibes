<div class="playlist-details" data-playlist-id="<%= playlistId %>"
     data-track-count="<%= totalTracks %>"
     data-needs-resync="<%= (hasYoutubeConnection && hasYoutubePlaylist && needsResync) ? 'true' : 'false' %>">
  <div class="playlist-header mb-3">
    <h6><%= playlistName %></h6>
    <div class="d-flex justify-content-between align-items-center">
      <span class="text-muted small">
        <%= totalTracks %> tracks<%= hasYoutubeConnection ? ` • ${linkedCount} linked` : '' %>
      </span>
      <button type="button" class="btn btn-outline-secondary btn-sm"
              data-refresh-playlist="<%= playlistId %>"
              hx-get="/api/playlistDetails/playlist/<%= playlistId %>"
              hx-target="closest .playlist-details-container"
              hx-swap="innerHTML"
              hx-headers='{"Cache-Control": "no-cache"}'
              title="Refresh playlist details">
        Refresh
      </button>
    </div>
    <% if (hasYoutubeConnection && hasYoutubePlaylist && needsResync) { %>
      <div class="resync-notice" role="status">
        <span class="resync-notice__dot" aria-hidden="true"></span>
        YouTube is out of sync with Spotify — re-sync to fix the order and add missing tracks.
      </div>
    <% } %>
  </div>

  <div class="tracks-list">
    <% tracks.forEach((track, index) => { %>
      <%# A row is "simple" (no thumbnail column) only when it has no image to show -
          neither album art nor a synced YouTube thumbnail. A row WITH album art must
          keep the full layout so the 120x120 image gets its grid column (otherwise it
          renders with inert grid props under the simple display:block layout). %>
      <div class="track-item <%= index % 2 === 0 ? 'track-item--even' : '' %> <%= (!track.spotify || !track.spotify.albumArt) && (!hasYoutubeConnection || !hasYoutubePlaylist) ? 'track-item--simple' : '' %>">
        <div class="track-number">
          <%= index + 1 %>
        </div>

        <div class="track-content flex-grow-1">
          <% if (track.spotify) { %>
            <div class="spotify-track">
              <div class="track-title fw-semibold" title="<%= track.spotify.name %>"><%= track.spotify.name %></div>
              <div class="track-artist text-muted small" title="<%= track.spotify.artist %> • <%= track.spotify.album %>"><%= track.spotify.artist %> • <%= track.spotify.album %></div>
            </div>
          <% } %>

          <% if (hasYoutubeConnection && hasYoutubePlaylist) { %>
            <% if (track.youtube) { %>
              <div class="youtube-video <%= track.spotify ? 'mt-1' : '' %>">
                <div class="d-flex align-items-center">
                  <img src="<%= track.youtube.thumbnail %>" alt="Video thumbnail"
                       class="youtube-video__thumbnail youtube-video__thumbnail--clickable"
                       data-video-url="<%= track.youtube.url %>"
                       role="button" tabindex="0">
                  <div class="flex-grow-1">
                    <div class="d-flex align-items-center gap-2">
                      <a href="<%= track.youtube.url %>" target="_blank" class="text-decoration-none small flex-grow-1" title="<%= track.youtube.title %>">
                        <%= track.youtube.title %>
                      </a>
                      <% if (track.matchScore) { %>
                        <%- include('./match-score-badge.ejs', { score: track.matchScore }) %>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            <% } else if (track.spotify) { %>
              <div class="youtube-video youtube-video--placeholder mt-1">
                <div class="d-flex align-items-center">
                  <div class="youtube-video__thumbnail youtube-video__thumbnail--placeholder">
                    <svg width="120" height="90" viewBox="0 0 120 90" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <rect width="120" height="90" fill="#e0e0e0"/>
                      <text x="60" y="50" text-anchor="middle" font-size="32" fill="#ccc" font-family="Arial">?</text>
                    </svg>
                  </div>
                  <div class="flex-grow-1">
                    <span class="text-muted small fst-italic">No video linked</span>
                  </div>
                </div>
              </div>
            <% } %>
          <% } else if (track.spotify && track.spotify.albumArt) { %>
            <!-- Show album art when YouTube is not connected -->
            <div class="youtube-video <%= track.spotify ? 'mt-1' : '' %>">
              <div class="d-flex align-items-center">
                <img src="<%= track.spotify.albumArt %>" alt="Album art for <%= track.spotify.album %>"
                     class="youtube-video__thumbnail youtube-video__thumbnail--album">
              </div>
            </div>
          <% } %>
        </div>

        <div class="track-status ms-2 d-flex align-items-center gap-2">
          <% if (hasYoutubeConnection && hasYoutubePlaylist) { %>
            <% if (track.linked && track.spotify) { %>
              <span class="badge bg-success">Linked</span>
              <button type="button" class="btn btn-outline-secondary btn-sm"
                      hx-get="/api/playlistDetails/search/<%= track.spotify.id %>?trackName=<%= encodeURIComponent(track.spotify.name) %>&artistName=<%= encodeURIComponent(track.spotify.artist) %>&playlistId=<%= playlistId %>&currentVideoId=<%= track.youtube?.id || '' %>"
                      hx-target="#video-modal-content"
                      hx-swap="innerHTML"
                      title="Edit linked video">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                </svg>
              </button>
            <% } else if (track.spotify) { %>
              <span class="badge bg-warning">Unlinked</span>
              <button type="button" class="btn btn-outline-secondary btn-sm"
                      hx-get="/api/playlistDetails/search/<%= track.spotify.id %>?trackName=<%= encodeURIComponent(track.spotify.name) %>&artistName=<%= encodeURIComponent(track.spotify.artist) %>&playlistId=<%= playlistId %>&currentVideoId="
                      hx-target="#video-modal-content"
                      hx-swap="innerHTML"
                      title="Link video to this track">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                </svg>
              </button>
            <% } else { %>
              <span class="badge bg-info">YouTube Only</span>
            <% } %>
          <% } else if (track.spotify) { %>
            <a href="https://open.spotify.com/track/<%= track.spotify.id %>" target="_blank"
               class="track-spotify-link" title="Open in Spotify">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="me-1">
                <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.42 1.56-.299.421-1.02.599-1.559.3z"/>
              </svg>
              Open
            </a>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>

  <!-- Collapse area at bottom of expanded details -->
  <label for="expand-<%= playlistId %>" class="playlist-collapse-area" data-playlist-id="<%= playlistId %>">
    <span class="collapse-indicator">▲</span>
  </label>
</div>
