<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>SLOPSYNC - component showcase</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="/css/fonts.css">
    <link href="/vendor/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/debug-components.css">
    <script src="/js/theme.js"></script>
</head>
<body>
    <%- include('./partials/print-filters') %>
    <%# Half this page's job is judging how components sit in BOTH themes; without a toggle it
        could only ever show whatever the OS happened to prefer. Same markup and same script as
        the real page, so the control being demonstrated is the real one. %>
    <button type="button" id="theme-toggle" class="theme-toggle" aria-label="Switch to dark theme" aria-pressed="false">
        <span class="theme-toggle__icon" aria-hidden="true"></span>
    </button>
    <div class="container mt-2">
        <div class="punk-header text-center mb-5">
            <h1 class="punk-title">
                <span class="punk-sigil" aria-hidden="true"><span class="punk-sigil__ink"></span></span>SHOWCASE<span class="punk-sigil punk-sigil--flip" aria-hidden="true"><span class="punk-sigil__ink"></span></span>
            </h1>
            <p class="punk-subtitle">every component, both themes, no spotify required</p>
        </div>

        <!-- ERROR MESSAGES -->
        <div class="component-section">
            <h2 class="component-title">Error Messages</h2>
            <p class="component-description">Error message components using real error-message.ejs template</p>

            <div class="component-demo">
                <div class="demo-label">Warning Message</div>
                <%- include('./partials/error-message.ejs', { message: 'Please connect to Spotify first', type: 'warning' }) %>
            </div>

            <div class="component-demo">
                <div class="demo-label">Danger Message</div>
                <%- include('./partials/error-message.ejs', { message: 'Error fetching playlists', type: 'danger' }) %>
            </div>

            <div class="component-demo">
                <div class="demo-label">Success Message</div>
                <%- include('./partials/error-message.ejs', { message: 'Playlists synced successfully!', type: 'success' }) %>
            </div>
        </div>

        <!-- PROGRESS UPDATES -->
        <div class="component-section">
            <h2 class="component-title">Progress Updates</h2>
            <p class="component-description">Sync progress, inside the status box the SSE stream actually swaps it into</p>

            <%# A progress frame NEVER appears on its own: the sync stream swaps it into
                .sync-status-content inside a .sync-status-box (see sync-subscriber.ejs), and that
                box brings its own state colour. Rendering the partial bare showed a component that
                does not exist anywhere in the app - which is exactly how the light-blue working box
                went unnoticed in dark mode.
                `state` maps type -> box state the way sync.ts does: a progress frame is 'working'
                until it terminates. %>
            <% [
                 { label: 'Working — searching', state: 'working', props: { type: 'progress', message: 'Finding music videos', percentage: 0, details: 'Searching for "One Day (feat. Mr. 3-2 & Ronnie Spencer)" by UGK... (1/38)' } },
                 { label: 'Working — adding', state: 'working', props: { type: 'progress', message: 'Adding new tracks to playlist', percentage: 45, details: '✓ Linked 45 tracks • ⚠ Unlinked 5 tracks' } },
                 { label: 'Complete', state: 'success', props: { type: 'complete', message: 'Sync Complete', percentage: 100, details: null } },
                 { label: 'Error', state: 'error', props: { type: 'error', message: 'Failed to sync playlist', percentage: null, details: null } }
               ].forEach((demo) => { %>
                <div class="component-demo">
                    <div class="demo-label"><%= demo.label %></div>
                    <%- include('./partials/sync-status-box.ejs', {
                          playlistId: 'demo-' + demo.state,
                          state: demo.state,
                          content: include('./partials/progress-update.ejs', demo.props)
                        }) %>
                </div>
            <% }); %>
        </div>

        <!-- PLAYLIST ITEMS -->
        <div class="component-section">
            <h2 class="component-title">Playlist Items</h2>
            <p class="component-description">Individual playlist items in different states using real playlist-item.ejs template</p>

            <% mockPlaylists.forEach((playlist) => { %>
                <div class="component-demo">
                    <div class="demo-label"><%= playlist.name %></div>
                    <%- include('./partials/playlist-item.ejs', playlist) %>
                </div>
            <% }); %>
        </div>

        <!-- PLAYLIST DETAILS -->
        <div class="component-section">
            <h2 class="component-title">Playlist Details</h2>
            <p class="component-description">Expanded playlist details showing tracks using real playlist-details.ejs template</p>

            <div class="component-demo">
                <div class="demo-label">Playlist with Linked Tracks — YouTube connected</div>
                <%- include('./partials/playlist-details.ejs', mockPlaylistDetails) %>
            </div>

            <%# The Spotify-only view, which the app renders whenever YouTube is not connected or
                the playlist is not synced. It was missing entirely, and it is the ONLY place the
                album-art bleed carries the row on its own - the linked view above puts a video
                preview over that same space. %>
            <div class="component-demo">
                <div class="demo-label">Not synced — Spotify only, album art carries the row</div>
                <%- include('./partials/playlist-details.ejs',
                      Object.assign({}, mockPlaylistDetails, {
                        hasYoutubeConnection: false,
                        hasYoutubePlaylist: false,
                        linkedCount: 0,
                        needsResync: false,
                      })) %>
            </div>
        </div>

        <!-- CONNECTION BUTTONS -->
        <div class="component-section">
            <h2 class="component-title">Connection Buttons</h2>
            <p class="component-description">Service connection status buttons in different states</p>

            <% mockConnectionButtonProps.forEach((props) => { %>
                <div class="component-demo">
                    <div class="demo-label"><%= props.service %> - <%= props.connected ? 'Connected' : (props.loading ? 'Loading' : 'Disconnected') %></div>
                    <%- include('./partials/connection-button.ejs', Object.assign({}, props, { isDebug })) %>
                </div>
            <% }); %>
        </div>

        <!-- SYNC FEEDBACK -->
        <div class="component-section">
            <h2 class="component-title">Sync Feedback Messages</h2>
            <p class="component-description">Success message after playlist sync completion</p>

            <div class="component-demo">
                <div class="demo-label">Sync Feedback - Multiple Videos Found</div>
                <%- include('./partials/sync-feedback.ejs', mockSyncFeedback) %>
            </div>
        </div>

        <!-- FORM CONTROLS -->
        <div class="component-section">
            <h2 class="component-title">Form Controls</h2>
            <p class="component-description">The search field and its hand-cut magnifier, plus the batch-size select</p>

            <%# The magnifier only exists on the real page, so it could not be reviewed here at all.
                Same markup as index.ejs - if the two drift, this stops being worth looking at. %>
            <div class="component-demo">
                <div class="demo-label">Playlist search — hand-cut magnifier (was an emoji)</div>
                <div class="search-input-wrapper">
                    <span class="search-icon" aria-hidden="true"></span>
                    <input type="text" class="form-control form-control-sm search-input"
                           placeholder="Search playlists and tracks..." autocomplete="off">
                </div>
            </div>

            <div class="component-demo">
                <div class="demo-label">Tracks per sync</div>
                <div class="d-flex align-items-center gap-2">
                    <label for="debugBatchSize" class="form-label mb-0 small text-nowrap">Tracks per sync:</label>
                    <select class="form-select form-select-sm batch-size-select" id="debugBatchSize">
                        <option value="1">1</option>
                        <option value="25">25</option>
                        <option value="all" selected>All</option>
                    </select>
                </div>
            </div>

            <div class="component-demo">
                <div class="demo-label">Own-playlists filter</div>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="debugOwnOnly" checked>
                    <label class="form-check-label" for="debugOwnOnly">Show only playlists I created</label>
                </div>
            </div>
        </div>

        <!-- SYNC BUTTONS -->
        <div class="component-section">
            <h2 class="component-title">Sync Buttons</h2>
            <p class="component-description">Sync action buttons in the states the fixtures describe</p>

            <%# Driven by each playlist's OWN state. This used to loop over hardcoded ids that did
                not exist ('demo-1'..'demo-3'), label every one with the FIRST playlist, and pass a
                hardcoded btn-primary "Sync to YouTube" - three identical buttons under a heading
                promising different states, while the fixtures already carried three real ones. %>
            <% mockPlaylists.forEach((playlist) => { %>
                <div class="component-demo">
                    <div class="demo-label"><%= playlist.name %> — <%= playlist.isSynced ? 'synced' : (playlist.isDisabled ? 'YouTube not connected' : 'not synced') %></div>
                    <% if (playlist.isDisabled) { %>
                        <%# This partial takes `message`, not `buttonText` - the two sync buttons do
                            not share an interface. %>
                        <%- include('./partials/sync-button-disabled.ejs', { message: playlist.buttonText, title: 'Connect to YouTube first' }) %>
                    <% } else { %>
                        <%- include('./partials/sync-button.ejs', {
                              playlistId: playlist.id,
                              playlistName: playlist.name,
                              trackCount: playlist.tracksTotal,
                              buttonClass: playlist.buttonClass,
                              buttonText: playlist.buttonText,
                              isDebug }) %>
                    <% } %>
                </div>
            <% }); %>
        </div>

        <!-- CONNECTION ERROR ALERTS -->
        <div class="component-section">
            <h2 class="component-title">Connection Error Alerts</h2>
            <p class="component-description">Error alerts when services fail to connect</p>

            <div class="component-demo">
                <div class="demo-label">Spotify Connection Error</div>
                <%- include('./partials/connection-error-alert.ejs', { spotifyError: 'Failed to authenticate with Spotify. Please check your credentials.', youtubeError: null }) %>
            </div>

            <div class="component-demo">
                <div class="demo-label">YouTube Connection Error</div>
                <%- include('./partials/connection-error-alert.ejs', { spotifyError: null, youtubeError: 'YouTube API quota exceeded. Please try again later.' }) %>
            </div>

            <div class="component-demo">
                <div class="demo-label">Both Services Error</div>
                <%- include('./partials/connection-error-alert.ejs', { spotifyError: 'Spotify connection failed', youtubeError: 'YouTube connection failed' }) %>
            </div>
        </div>

        <!-- SUCCESS MESSAGES -->
        <div class="component-section">
            <h2 class="component-title">Success Messages</h2>
            <p class="component-description">What POST /api/playlistDetails/replace/:trackId returns after the video modal</p>

            <%# These are the ONLY three strings the app can produce (playlistDetails.ts ~452). The
                showcase used to invent "Video successfully linked to track", which nothing anywhere
                generates - so the one component on this page nobody could place was a component
                showing copy that does not exist. The third is the interesting one and was never
                shown at all: the write landed but the track could not be positioned. %>
            <% [
                 ['Linked (add)', 'Video linked successfully!'],
                 ['Replaced', 'Video replaced successfully!'],
                 ['Linked but not placed', 'Video linked, but it could not be moved into position - sync the playlist to fix the order.']
               ].forEach(([label, message]) => { %>
                <div class="component-demo">
                    <div class="demo-label"><%= label %></div>
                    <%- include('./partials/video-replace-success.ejs', { message }) %>
                </div>
            <% }); %>
        </div>

        <!-- BACK TO HOME -->
        <div class="text-center mb-5">
            <a href="/" class="btn btn-outline-secondary">← Back to Home</a>
        </div>
    </div>
    <script src="/js/logger.js"></script>
    <script src="/js/themeToggle.js"></script>
</body>
</html>
