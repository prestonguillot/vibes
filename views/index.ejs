<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="referrer" content="strict-origin-when-cross-origin">
    <title>Spotify to YouTube Playlist Sync</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <!-- Self-hosted display fonts (no third-party request; regenerate via scripts/fetch-fonts.mjs) -->
    <link rel="stylesheet" href="/css/fonts.css">
    <link href="/vendor/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <!-- Set the theme before first paint (avoids a flash); defaults to the OS setting -->
    <script src="/js/theme.js"></script>
    <script src="/vendor/htmx.min.js"></script>
    <script src="/vendor/sse.min.js"></script>
</head>
<body<% if (csrfToken) { %> hx-headers='{"X-CSRF-Token": "<%= csrfToken %>"}'<% } %>>
    <button type="button" id="theme-toggle" class="theme-toggle" aria-label="Switch to dark theme" aria-pressed="false">
        <span class="theme-toggle__icon" aria-hidden="true">☾</span>
    </button>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="punk-header text-center">
                    <h1 class="punk-title">SPOTIFY <span class="punk-arrow">→</span> YOUTUBE</h1>
                    <p class="punk-subtitle">Sync your playlists with music videos</p>
                </div>

                <!-- Connection Status -->
                <div class="row mb-4">
                    <div class="col-md-6 mb-3">
                        <div class="card h-100">
                            <div class="card-body text-center">
                                <h5 class="card-title">SPOTIFY</h5>
                                <%# Loaded once. Every operation validates and refreshes its own
                                    token on demand, so polling keeps nothing alive - it would only
                                    re-check a connection nobody is using. %>
                                <div id="spotify-status"
                                     hx-get="/api/status/spotify/button"
                                     hx-trigger="load"
                                     hx-swap="innerHTML">
                                    <button class="btn btn-success connect-btn disabled" disabled>
                                        <span class="d-flex align-items-center justify-content-center">
                                            <div class="spinner-border spinner-border-sm spinner-xs me-2" role="status" aria-hidden="true"></div>
                                            Checking connection...
                                        </span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="card h-100">
                            <div class="card-body text-center">
                                <h5 class="card-title">YOUTUBE</h5>
                                <div id="youtube-status"
                                     hx-get="/api/status/youtube/button"
                                     hx-trigger="load"
                                     hx-swap="innerHTML">
                                    <button class="btn btn-danger connect-btn disabled" disabled>
                                        <span class="d-flex align-items-center justify-content-center">
                                            <div class="spinner-border spinner-border-sm spinner-xs me-2" role="status" aria-hidden="true"></div>
                                            Checking connection...
                                        </span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Playlists Section -->
                <div class="card playlists-panel">
                    <div class="card-header">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Your Playlists</h5>
                            <button id="refresh-playlists-btn" class="btn btn-outline-primary btn-sm disabled"
                                    disabled
                                    hx-get="/auth/spotify/playlists"
                                    hx-include="#ownPlaylistsOnly"
                                    hx-target="#playlists-content"
                                    hx-headers='{"Cache-Control": "no-cache"}'
                                    hx-indicator="#loading"
                                    title="Connect to both Spotify and YouTube to refresh">
                                Refresh
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-12">
                                <div class="mb-3">
                                    <div class="row g-3">
                                        <div class="col-12 col-sm-auto">
                                            <div class="d-flex align-items-center gap-2">
                                                <label for="syncBatchSize" class="form-label mb-0 small text-nowrap">Tracks per sync:</label>
                                                <select class="form-select form-select-sm batch-size-select" name="batchSize" id="syncBatchSize">
                                                    <option value="1">1</option>
                                                    <option value="10">10</option>
                                                    <option value="25">25</option>
                                                    <option value="50">50</option>
                                                    <option value="100">100</option>
                                                    <option value="all" selected>All</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-12 col-sm-auto">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" id="ownPlaylistsOnly" checked
                                                       name="ownOnly" value="true"
                                                       hx-get="/auth/spotify/playlists"
                                                       hx-target="#playlists-content"
                                                       hx-trigger="change"
                                                       hx-swap="innerHTML">
                                                <label class="form-check-label" for="ownPlaylistsOnly">
                                                    Show only playlists I created
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- Playlist Search -->
                                <div class="mb-3">
                                    <div class="search-input-wrapper">
                                        <span class="search-icon">🔍</span>
                                        <input
                                            type="text"
                                            id="playlistSearch"
                                            class="form-control form-control-sm search-input"
                                            placeholder="Search playlists and tracks..."
                                            autocomplete="off">
                                    </div>
                                </div>
                                <div id="playlists-content"
                                     hx-get="/auth/spotify/playlists"
                                     hx-include="#ownPlaylistsOnly"
                                     hx-trigger="load">
                                    <div class="punk-alert punk-alert--loading">
                                        <div class="d-flex align-items-center justify-content-center gap-3">
                                            <div class="loading-spinner"></div>
                                            <div>
                                                <div class="punk-alert__title">Loading Playlists</div>
                                                <small class="punk-alert__details">Fetching your Spotify playlists...</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Loading Indicator -->
                <div id="loading" class="loading-indicator text-center mt-3">
                    <div class="custom-punk-spinner"></div>
                    <p class="mt-2">Syncing playlist...</p>
                    <small class="text-muted">This may take a moment while we search for videos</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Global video-selection modal (native <dialog>) -->
    <dialog id="videoSelectionModal" class="video-modal" aria-labelledby="videoSelectionModalLabel">
        <div class="modal-content">
            <div id="video-modal-content">
                <div class="modal-body text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2">Loading video options...</p>
                </div>
            </div>
        </div>
    </dialog>

    <!-- OAuth Connection Error Modal -->
    <dialog class="connection-error-modal" id="connectionErrorModal" aria-labelledby="connectionErrorLabel">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="connectionErrorLabel">Connection Failed</h5>
          <button type="button" class="btn-close" data-dialog-close aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="modal-message" id="connectionErrorMessage">
            <!-- Error message will be inserted here -->
          </p>
          <div class="text-center">
            <button type="button" class="btn btn-error-modal" data-dialog-close>OK</button>
          </div>
        </div>
      </div>
    </dialog>

    <!-- External JavaScript Modules -->
    <script src="/js/logger.js"></script>
    <script src="/js/themeToggle.js"></script>
    <script src="/js/eventLogging.js"></script>
    <script src="/js/videoModal.js"></script>
    <script src="/js/sync.js"></script>
    <script src="/js/playlistFilter.js"></script>
    <script src="/js/playlistSearch.js"></script>
    <script src="/js/playlistScroll.js"></script>
    <script src="/js/youtubeConnectionRefresh.js"></script>
    <script src="/js/youtubeCache.js"></script>
    <script src="/js/playlistMeta.js"></script>
    <script src="/js/dismissAlert.js"></script>
    <script src="/js/indexPage.js"></script>
</body>
</html>
