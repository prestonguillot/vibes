{
  "name": "spotify-youtube-sync",
  "version": "1.0.0",
  "description": "Sync Spotify playlists to YouTube playlists with music videos",
  "main": "dist/server.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/server.ts",
    "build": "tsc",
    "start": "NODE_ENV=production node dist/server.js",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:spotify:live": "vitest run --config vitest.live.config.ts"
  },
  "keywords": [
    "spotify",
    "youtube",
    "playlist",
    "sync",
    "htmx"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.0.3",
    "ejs": "^3.1.10",
    "express": "^4.18.2",
    "googleapis": "^173.0.0",
    "helmet": "^8.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.17",
    "@types/node": "^20.5.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "supertest": "^7.1.4",
    "tsx": "^4.22.4",
    "typescript": "^5.1.6",
    "vitest": "^3.2.4"
  }
}
