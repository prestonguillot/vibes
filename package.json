{
  "name": "spotify-youtube-sync",
  "version": "1.0.0",
  "description": "Sync Spotify playlists to YouTube playlists with music videos",
  "main": "dist/server.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/server.ts",
    "build": "tsc",
    "start": "NODE_ENV=production node dist/server.js",
    "type-check": "tsc --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:spotify:live": "vitest run --config vitest.live.config.ts",
    "test:visual": "playwright test",
    "test:visual:argos": "playwright test --config playwright.argos.config.ts",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "vendor": "cp node_modules/htmx.org/dist/htmx.min.js public/vendor/htmx.min.js && cp node_modules/bootstrap/dist/css/bootstrap.min.css public/vendor/bootstrap.min.css && cp node_modules/htmx-ext-sse/dist/sse.min.js public/vendor/sse.min.js",
    "audit:css": "node scripts/css-important-analysis.mjs",
    "type-check:tests": "tsc -p tsconfig.test.json"
  },
  "keywords": [
    "spotify",
    "youtube",
    "playlist",
    "sync",
    "htmx"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@argos-ci/playwright": "^7.1.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "bootstrap": "5.3.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.10.6",
    "htmx-ext-sse": "2.2.4",
    "htmx.org": "2.0.10",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
