# Server Configuration
PORT=3000
NODE_ENV=development

# Security Configuration
# CSRF_SECRET is required in production. In development, a random secret is auto-generated.
# Generate a production secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CSRF_SECRET=<generated-32-byte-hex-string>

# Rate Limiting Configuration
# All rate limiters are enabled by default and disabled during testing (NODE_ENV=test)
# Set RATE_LIMITING_ENABLED=false to disable all rate limiting
# RATE_LIMITING_ENABLED=true

# Sync endpoint rate limiting (1 request per second by default)
# SYNC_RATE_LIMIT_WINDOW_MS=1000
# SYNC_RATE_LIMIT_MAX_REQUESTS=1

# Playlists endpoint rate limiting (1 request per second by default)
# PLAYLISTS_RATE_LIMIT_WINDOW_MS=1000
# PLAYLISTS_RATE_LIMIT_MAX_REQUESTS=1

# Logging Configuration
# Set LOG_LEVEL to control verbosity: DEBUG, INFO, WARN, or ERROR
# Default: DEBUG in development, INFO in production
# LOG_LEVEL=DEBUG

# Spotify API Configuration
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback

# YouTube API Configuration
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/auth/youtube/callback
YOUTUBE_API_KEY=your-youtube-api-key
