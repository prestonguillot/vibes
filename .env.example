# Server Configuration
PORT=3000
NODE_ENV=development

# Security Configuration
# CSRF_SECRET is required in production. In development, a random secret is auto-generated.
# Generate a production secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CSRF_SECRET=<generated-32-byte-hex-string>

# Logging Configuration
# Set LOG_LEVEL to control verbosity: DEBUG, INFO, WARN, or ERROR
# Default: DEBUG in development, INFO in production
# LOG_LEVEL=DEBUG

# Spotify API Configuration
# Spotify now requires 127.0.0.1 (not localhost) for loopback redirect URIs.
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/auth/spotify/callback

# YouTube API Configuration (OAuth only - search uses no API key)
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://127.0.0.1:3000/auth/youtube/callback
