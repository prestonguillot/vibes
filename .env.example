# Server Configuration
PORT=3000
NODE_ENV=development

# Security Configuration
# CSRF_SECRET is required in production. In development, a random secret is auto-generated.
# Generate a production secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CSRF_SECRET=<generated-32-byte-hex-string>
# ENABLE_RATE_LIMITING=false  # Set to 'true' to enable rate limiting on sync operations (5 requests per 5 minutes)

# Spotify API Configuration
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback

# YouTube API Configuration
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/auth/youtube/callback
YOUTUBE_API_KEY=your-youtube-api-key
